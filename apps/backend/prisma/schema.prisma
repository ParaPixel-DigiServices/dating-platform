generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/////////////////////////////////////////////////
// ENUMS
/////////////////////////////////////////////////

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum VerificationType {
  PHONE
  EMAIL
  SELFIE
  GOVERNMENT_ID
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

/////////////////////////////////////////////////
// USERS
/////////////////////////////////////////////////

model User {
  id String @id @default(uuid()) @db.Uuid

  // Authentication
  firebaseUid String @unique

  phoneNumber String? @unique
  email       String? @unique

  // Authorization
  role   UserRole   @default(USER)
  status UserStatus @default(ACTIVE)

  // Activity
  lastActiveAt DateTime?

  // Relations
  devices       Device[]
  sessions      Session[]
  verifications UserVerification[]
  profile       Profile?

  moderationActionsReceived  ModerationAction[] @relation("UserModerationActions")
  moderationActionsPerformed ModerationAction[] @relation("AdminModerationActions")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([lastActiveAt])
}

/////////////////////////////////////////////////
// DEVICES
/////////////////////////////////////////////////

model Device {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceName String?

  platform DevicePlatform

  appVersion String?

  pushToken String? @unique

  lastActiveAt DateTime?

  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/////////////////////////////////////////////////
// SESSIONS
/////////////////////////////////////////////////

model Session {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceId String @db.Uuid
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  refreshTokenHash String

  ipAddress String?

  userAgent String?

  expiresAt DateTime

  lastUsedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  revokedAt DateTime?

  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt])
  @@index([revokedAt])
}

/////////////////////////////////////////////////
// USER VERIFICATIONS
/////////////////////////////////////////////////

model UserVerification {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  type VerificationType

  status VerificationStatus @default(PENDING)

  rejectionReason String?

  verifiedAt DateTime?

  reviewedById String? @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
  @@index([status])
}

/////////////////////////////////////////////////
// PROFILE ENUMS
/////////////////////////////////////////////////

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EducationLevel {
  HIGH_SCHOOL
  DIPLOMA
  BACHELORS
  MASTERS
  PHD
  OTHER
}

enum DietPreference {
  VEGETARIAN
  NON_VEGETARIAN
  EGGETARIAN
  VEGAN
  OTHER
}

enum SmokingHabit {
  NEVER
  OCCASIONALLY
  REGULARLY
}

enum DrinkingHabit {
  NEVER
  OCCASIONALLY
  REGULARLY
}

enum ImportanceLevel {
  LOW
  MEDIUM
  HIGH
}

enum PersonalityType {
  INTROVERT
  EXTROVERT
  AMBIVERT
}

enum SleepPreference {
  MORNING_PERSON
  NIGHT_OWL
}

enum SocialLevel {
  LOW
  MODERATE
  HIGH
}

enum CleanlinessLevel {
  LOW
  MODERATE
  HIGH
}

model Religion {
  id String @id @default(uuid()) @db.Uuid

  name String @unique

  displayOrder Int?

  isActive Boolean @default(true)

  castes Caste[]

  profiles Profile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Caste {
  id String @id @default(uuid()) @db.Uuid

  religionId String @db.Uuid

  religion Religion @relation(fields: [religionId], references: [id])

  name String

  parentCasteId String? @db.Uuid

  parentCaste Caste? @relation("CasteHierarchy", fields: [parentCasteId], references: [id])

  childCastes Caste[] @relation("CasteHierarchy")

  state String?

  displayOrder Int?

  isActive Boolean @default(true)

  profiles Profile[]

  preferredByPartnerCastes PartnerPreferredCaste[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([religionId, name])
  @@index([religionId, state])
}

model Profile {
  id String @id @default(uuid()) @db.Uuid

  userId String @unique @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  // Identity

  firstName String

  lastName String

  dateOfBirth DateTime @db.Date

  gender Gender

  bio String?

  // Location

  city String?

  state String?

  country String?

  // Education & Career

  educationLevel EducationLevel?

  college String?

  occupation String?

  // Financial

  annualIncome Decimal? @db.Decimal(15, 2)

  familyIncome Decimal? @db.Decimal(15, 2)

  incomeCurrency String? @default("INR")

  assets String?

  // Cultural

  religionId String? @db.Uuid

  religion Religion? @relation(fields: [religionId], references: [id])

  casteId String? @db.Uuid

  caste Caste? @relation(fields: [casteId], references: [id])

  motherTongue String?

  // Lifestyle

  dietPreference DietPreference?

  smokingHabit SmokingHabit?

  drinkingHabit DrinkingHabit?

  fitnessImportance ImportanceLevel?

  petsPreference ImportanceLevel?

  // Personality

  personalityType PersonalityType?

  sleepPreference SleepPreference?

  communicationStyle String?

  conflictResolutionStyle String?

  socialLevel SocialLevel?

  cleanlinessLevel CleanlinessLevel?

  // Completion

  completionPercentage Int @default(0)

  isCompleted Boolean @default(false)

  // Relations

  categories UserCategory[]

  photos ProfilePhoto[]

  languages UserLanguage[]

  interests UserInterest[]

  loveProfile LoveProfile?

  marriageProfile MarriageProfile?

  partnerPreference PartnerPreference?

  sentInteractions ProfileInteraction[] @relation("InteractionSender")

  receivedInteractions ProfileInteraction[] @relation("InteractionReceiver")

  matchesAsProfileOne Match[] @relation("MatchProfileOne")

  matchesAsProfileTwo Match[] @relation("MatchProfileTwo")

  messagesSent Message[]

  blocksCreated Block[] @relation("ProfileBlocks")

  blockedBy Block[] @relation("BlockedByProfiles")

  reportsCreated Report[] @relation("ReportsCreated")

  reportsReceived Report[] @relation("ReportsReceived")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  deletedAt DateTime?

  @@index([city, state, country])
  @@index([gender])
  @@index([religionId])
  @@index([casteId])
  @@index([religionId, state])
}

enum PhotoModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model ProfilePhoto {
  id String @id @default(uuid()) @db.Uuid

  profileId String @db.Uuid

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  storageKey String

  cdnUrl String

  displayOrder Int

  isPrimary Boolean @default(false)

  moderationStatus PhotoModerationStatus @default(PENDING)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([profileId])
}

model Language {
  id String @id @default(uuid()) @db.Uuid

  name String @unique

  code String @unique

  displayOrder Int?

  isActive Boolean @default(true)

  users UserLanguage[]

  preferredByPartnerLanguages PartnerPreferredLanguage[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

enum LanguageProficiency {
  BASIC
  CONVERSATIONAL
  FLUENT
  NATIVE
}

model UserLanguage {
  id String @id @default(uuid()) @db.Uuid

  profileId String @db.Uuid

  languageId String @db.Uuid

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  language Language @relation(fields: [languageId], references: [id])

  proficiency LanguageProficiency?

  createdAt DateTime @default(now())

  @@unique([profileId, languageId])
}

model Interest {
  id String @id @default(uuid()) @db.Uuid

  name String @unique

  category String?

  displayOrder Int?

  isActive Boolean @default(true)

  users UserInterest[]

  preferredByPartnerInterests PartnerPreferredInterest[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model UserInterest {
  id String @id @default(uuid()) @db.Uuid

  profileId String @db.Uuid

  interestId String @db.Uuid

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  interest Interest @relation(fields: [interestId], references: [id])

  createdAt DateTime @default(now())

  @@unique([profileId, interestId])
}

/////////////////////////////////////////////////
// CATEGORY ENUMS
/////////////////////////////////////////////////

enum CategoryType {
  LOVE
  MARRIAGE
}

enum UserJourneyStatus {
  ACTIVE
  COMPLETED
  SWITCHED
}

/////////////////////////////////////////////////
// LOVE ENUMS
/////////////////////////////////////////////////

enum RelationshipIntent {
  LONG_TERM
  OPEN_TO_MARRIAGE
  UNDECIDED
}

/////////////////////////////////////////////////
// MARRIAGE ENUMS
/////////////////////////////////////////////////

enum MarriageTimeline {
  IMMEDIATE
  WITHIN_ONE_YEAR
  FAMILY_SEARCHING
  EXPLORING_SERIOUSLY
  REMARRIAGE
}

enum FamilyType {
  JOINT
  NUCLEAR
}

model Category {
  id String @id @default(uuid()) @db.Uuid

  type CategoryType @unique

  description String?

  subCategories SubCategory[]

  users UserCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SubCategory {
  id String @id @default(uuid()) @db.Uuid

  categoryId String @db.Uuid

  category Category @relation(fields: [categoryId], references: [id])

  name String

  description String?

  isActive Boolean @default(true)

  users UserCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, name])
}

model UserCategory {
  id String @id @default(uuid()) @db.Uuid

  profileId String @db.Uuid

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  categoryId String @db.Uuid

  category Category @relation(fields: [categoryId], references: [id])

  subCategoryId String @db.Uuid

  subCategory SubCategory @relation(fields: [subCategoryId], references: [id])

  isCurrent Boolean @default(true)

  startedAt DateTime @default(now())

  endedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([isCurrent])
  @@index([profileId, isCurrent])
}

model LoveProfile {
  id String @id @default(uuid()) @db.Uuid

  profileId String @unique @db.Uuid

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  voiceIntroUrl String?

  videoIntroUrl String?

  prompts LovePromptAnswer[]

  compatibility LoveCompatibility?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LovePrompt {
  id String @id @default(uuid()) @db.Uuid

  text String

  displayOrder Int?

  isActive Boolean @default(true)

  answers LovePromptAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LovePromptAnswer {
  id String @id @default(uuid()) @db.Uuid

  loveProfileId String @db.Uuid

  loveProfile LoveProfile @relation(fields: [loveProfileId], references: [id], onDelete: Cascade)

  promptId String @db.Uuid

  prompt LovePrompt @relation(fields: [promptId], references: [id])

  answer String @db.Text

  displayOrder Int

  createdAt DateTime @default(now())

  @@unique([loveProfileId, promptId])
}

model LoveCompatibility {
  id String @id @default(uuid()) @db.Uuid

  loveProfileId String @unique @db.Uuid

  loveProfile LoveProfile @relation(fields: [loveProfileId], references: [id], onDelete: Cascade)

  relationshipIntent RelationshipIntent

  religiousCompatibilityImportance Int

  wantsChildren Boolean?

  openToRelocation Boolean?

  comfortableLongDistance Boolean?

  comfortablePoliticalDiscussions Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/////////////////////////////////////////////////
// MARRIAGE ENUMS
/////////////////////////////////////////////////

enum MaritalStatus {
  NEVER_MARRIED
  DIVORCED
  WIDOWED
}

enum RelocationPreference {
  DOMESTIC
  ABROAD
  BOTH
  NOT_WILLING
}

enum PreferenceLevel {
  LOW
  MEDIUM
  HIGH
}

enum PracticeFrequency {
  NEVER
  OCCASIONALLY
  MONTHLY
  WEEKLY
  DAILY
}

enum LifestyleType {
  MODERN
  TRADITIONAL
  BALANCED
}

enum WeddingType {
  SIMPLE
  TRADITIONAL
  LUXURY
  DESTINATION
  TEMPLE
  CHURCH
  MOSQUE
  GURDWARA
  MINIMAL
}

model MarriageProfile {
  id String @id @default(uuid()) @db.Uuid

  profileId String @unique @db.Uuid

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  lookingFor String?

  marriageTimeline MarriageTimeline?

  residence String?

  maritalStatus MaritalStatus?

  hasChildren   Boolean?
  childrenCount Int?

  siblingsCount Int?

  familyType FamilyType?

  parentalConsentRequired Boolean?

  wantsChildren Boolean?

  relocationPreference RelocationPreference?

  partnerExpectations String?

  dealBreakers String?

  financialResponsibility PreferenceLevel?

  angerManagement PreferenceLevel?

  travelInterest PreferenceLevel?

  hinduProfile HinduMarriageProfile?

  muslimProfile MuslimMarriageProfile?

  christianProfile ChristianMarriageProfile?

  sikhProfile SikhMarriageProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
