  templeVisitFrequency PracticeFrequency?

  fastingPreferences String[]

  ritualPreferences String[]

  touchesElderFeet Boolean?

  // Lifestyle

  nonVegAtHomeAccepted Boolean?

  alcoholAcceptance PreferenceLevel?

  smokingAcceptance PreferenceLevel?

  dressingStyle LifestyleType?

  genderRolePreference LifestyleType?

  tattooAccepted Boolean?

  clubbingAccepted Boolean?

  oppositeGenderFriendAcceptance PreferenceLevel?

  // Marriage

  casteConscious Boolean?

  intercasteMarriageAccepted Boolean?

  sameFamilyStatusExpected Boolean?

  workingPartnerPreference PreferenceLevel?

  acceptDivorcee Boolean?

  weddingPreference WeddingType?

  wearsThali Boolean?

  // Household

  vastuImportance PreferenceLevel?

  separatePoojaRoom Boolean?

  livingNearTemplePreference Boolean?

  hinduSymbolsAtHome Boolean?

  childrenLearnSanskrit Boolean?

  templeDonationImportance PreferenceLevel?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MuslimSect {
  id String @id @default(uuid()) @db.Uuid

  name String @unique

  description String?

  displayOrder Int?

  isActive Boolean @default(true)

  communities MuslimCommunity[]

  profiles MuslimMarriageProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MuslimCommunity {
  id String @id @default(uuid()) @db.Uuid

  sectId String? @db.Uuid

  sect MuslimSect? @relation(fields: [sectId], references: [id])

  name String @unique

  region String?

  displayOrder Int?

  isActive Boolean @default(true)

  profiles MuslimMarriageProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MuslimMarriageProfile {
  id String @id @default(uuid()) @db.Uuid

  marriageProfileId String @unique @db.Uuid

  marriageProfile MarriageProfile @relation(fields: [marriageProfileId], references: [id], onDelete: Cascade)

  // Identity

  sectId String?     @db.Uuid
  sect   MuslimSect? @relation(fields: [sectId], references: [id])

  communityId String?          @db.Uuid
  community   MuslimCommunity? @relation(fields: [communityId], references: [id])

  // Faith & Practices

  practiceLevel PreferenceLevel?

  prayerFrequency PracticeFrequency?

  tahajjudPractice Boolean?

  quranReadingFrequency PracticeFrequency?

  ramadanObservance PreferenceLevel?

  zakatImportance PreferenceLevel?

  hajjUmrahPlan String?

  followsScholar Boolean?

  // Lifestyle

  hijabPreference PreferenceLevel?

  beardPreference PreferenceLevel?

  halalLifestyleRequired Boolean?

  interestFreeLifeImportance PreferenceLevel?

  westernFestivalAcceptance Boolean?

  // Marriage

  nikahPreference WeddingType?

  mehrImportance PreferenceLevel?

  polygamyAcceptance Boolean?

  womanWorkingAfterMarriage PreferenceLevel?

  acceptDivorcee Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChristianDenomination {
  id String @id @default(uuid()) @db.Uuid

  name String @unique

  description String?

  displayOrder Int?

  isActive Boolean @default(true)

  profiles ChristianMarriageProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChristianMarriageProfile {
  id String @id @default(uuid()) @db.Uuid

  marriageProfileId String @unique @db.Uuid

  marriageProfile MarriageProfile @relation(fields: [marriageProfileId], references: [id], onDelete: Cascade)

  // Faith & Practices

  denominationId String? @db.Uuid

  denomination ChristianDenomination? @relation(fields: [denominationId], references: [id])

  churchAttendanceFrequency PracticeFrequency?

  bibleReadingFrequency PracticeFrequency?

  prayerRoutines String[]

  fastingRetreatImportance PreferenceLevel?

  pastorGuidanceImportance PreferenceLevel?

  // Church Life

  churchServiceParticipation Boolean?

  choirParticipation Boolean?

  churchCharityImportance PreferenceLevel?

  // Lifestyle & Boundaries

  modestDressingPreference PreferenceLevel?

  porkAcceptance Boolean?

  alcoholAcceptance PreferenceLevel?

  smokingAcceptance PreferenceLevel?

  clubbingAcceptance Boolean?

  livingNearChurchImportance PreferenceLevel?

  religiousSymbolsAtHome Boolean?

  entertainmentIndustryAcceptance Boolean?

  phonePasswordSharingPreference PreferenceLevel?

  pdaComfortLevel PreferenceLevel?

  tattooAcceptance Boolean?

  socialMediaModestyImportance PreferenceLevel?

  therapyAcceptance Boolean?

  // Marriage & Family

  churchMarriageRequired Boolean?

  premaritalCounsellingRequired Boolean?

  weddingPreference WeddingType?

  interDenominationAcceptance Boolean?

  husbandSpiritualHeadPreference PreferenceLevel?

  purityBeforeMarriageImportance PreferenceLevel?

  childrenBaptismPreference Boolean?

  christianSchoolPreference Boolean?

  familyValuesOrientation LifestyleType?

  parentingStyle PreferenceLevel?

  adoptionAcceptance Boolean?

  acceptDivorcee Boolean?

  anniversaryImportance PreferenceLevel?

  financialTransparencyImportance PreferenceLevel?

  savingMoneyImportance PreferenceLevel?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model SikhReligiousStatus {
  id String @id @default(uuid()) @db.Uuid

  name String @unique

  description String?

  displayOrder Int?

  isActive Boolean @default(true)

  profiles SikhMarriageProfile[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model SikhMarriageProfile {
  id String @id @default(uuid()) @db.Uuid

  marriageProfileId String @unique @db.Uuid

  marriageProfile MarriageProfile @relation(fields: [marriageProfileId], references: [id], onDelete: Cascade)

  // Faith & Practices

  religiousStatusId String? @db.Uuid

  religiousStatus SikhReligiousStatus? @relation(fields: [religiousStatusId], references: [id])

  nitnemFrequency PracticeFrequency?

  gurdwaraVisitFrequency PracticeFrequency?

  turbanPreference PreferenceLevel?

  keshImportance PreferenceLevel?

  sevaParticipationImportance PreferenceLevel?

  // Lifestyle & Values

  dietPreference DietPreference?

  alcoholAcceptance PreferenceLevel?

  smokingAcceptance PreferenceLevel?

  lifestyleOrientation LifestyleType?

  // Marriage & Family

  casteConscious Boolean?

  anandKarajPreference WeddingType?

  interCasteAcceptance Boolean?

  workingPartnerPreference PreferenceLevel?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model PartnerPreference {
  id String @id @default(uuid()) @db.Uuid

  //////////////////////////////////////////////////
  // Ownership
  //////////////////////////////////////////////////

  profileId String @unique @db.Uuid

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////
  // HARD DISCOVERY FILTERS
  //////////////////////////////////////////////////

  ageFilterEnabled Boolean @default(false)

  minAge Int?

  maxAge Int?

  heightFilterEnabled Boolean @default(false)

  minHeightCm Int?

  maxHeightCm Int?

  distanceFilterEnabled Boolean @default(false)

  maxDistanceKm Int?

  casteFilterEnabled Boolean @default(false)

  languageFilterEnabled Boolean @default(false)

  educationFilterEnabled Boolean @default(false)

  minimumEducationLevel EducationLevel?

  incomeFilterEnabled Boolean @default(false)

  minimumAnnualIncome Decimal? @db.Decimal(15, 2)

  //////////////////////////////////////////////////
  // SOFT COMPATIBILITY WEIGHTS
  // 0 - Not important
  // 100 - Extremely important
  //////////////////////////////////////////////////

  valuesWeight Int @default(100)

  lifestyleWeight Int @default(90)

  communicationWeight Int @default(90)

  conflictResolutionWeight Int @default(90)

  familyWeight Int @default(95)

  interestsWeight Int @default(60)

  careerWeight Int @default(40)

  personalityWeight Int @default(85)

  //////////////////////////////////////////////////
  // Relationships
  //////////////////////////////////////////////////

  preferredCastes PartnerPreferredCaste[]

  preferredLanguages PartnerPreferredLanguage[]

  preferredInterests PartnerPreferredInterest[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([profileId])
}

model PartnerPreferredCaste {
  id String @id @default(uuid()) @db.Uuid

  partnerPreferenceId String @db.Uuid

  casteId String @db.Uuid

  partnerPreference PartnerPreference @relation(fields: [partnerPreferenceId], references: [id], onDelete: Cascade)

  caste Caste @relation(fields: [casteId], references: [id])

  createdAt DateTime @default(now())

  @@unique([partnerPreferenceId, casteId])
  @@index([casteId])
}

model PartnerPreferredLanguage {
  id String @id @default(uuid()) @db.Uuid

  partnerPreferenceId String @db.Uuid

  languageId String @db.Uuid

  partnerPreference PartnerPreference @relation(fields: [partnerPreferenceId], references: [id], onDelete: Cascade)

  language Language @relation(fields: [languageId], references: [id])

  createdAt DateTime @default(now())

  @@unique([partnerPreferenceId, languageId])
  @@index([languageId])
}

model PartnerPreferredInterest {
  id String @id @default(uuid()) @db.Uuid

  partnerPreferenceId String @db.Uuid

  interestId String @db.Uuid

  partnerPreference PartnerPreference @relation(fields: [partnerPreferenceId], references: [id], onDelete: Cascade)

  interest Interest @relation(fields: [interestId], references: [id])

  createdAt DateTime @default(now())

  @@unique([partnerPreferenceId, interestId])
  @@index([interestId])
}

/////////////////////////////////////////////////
// INTERACTION ENUMS
/////////////////////////////////////////////////

enum InteractionType {
  LIKE
  PASS
  SUPER_LIKE
}

enum MatchStatus {
  ACTIVE
  UNMATCHED
}

model ProfileInteraction {
  id String @id @default(uuid()) @db.Uuid

  fromProfileId String @db.Uuid

  fromProfile Profile @relation("InteractionSender", fields: [fromProfileId], references: [id], onDelete: Cascade)

  toProfileId String @db.Uuid

  toProfile Profile @relation("InteractionReceiver", fields: [toProfileId], references: [id], onDelete: Cascade)

  interactionType InteractionType

  createdAt DateTime @default(now())

  @@unique([fromProfileId, toProfileId])
  @@index([toProfileId, interactionType])
  @@index([fromProfileId])
  @@index([toProfileId])
  @@index([interactionType])
}

model Match {
  id String @id @default(uuid()) @db.Uuid

  profileOneId String @db.Uuid

  profileOne Profile @relation("MatchProfileOne", fields: [profileOneId], references: [id], onDelete: Cascade)

  profileTwoId String @db.Uuid

  profileTwo Profile @relation("MatchProfileTwo", fields: [profileTwoId], references: [id], onDelete: Cascade)

  status MatchStatus @default(ACTIVE)

  matchedAt DateTime @default(now())

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  chat Chat?

  @@unique([profileOneId, profileTwoId])
  @@index([profileOneId])
  @@index([profileTwoId])
  @@index([status])
}

enum MessageType {
  TEXT
  IMAGE
  VOICE
  VIDEO
  SYSTEM
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  DELETED
}

model Chat {
  id String @id @default(uuid()) @db.Uuid

  matchId String @unique @db.Uuid

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  lastMessageAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  messages Message[]

  @@index([lastMessageAt])
}

model Message {
  id String @id @default(uuid()) @db.Uuid

  chatId String @db.Uuid

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  senderProfileId String @db.Uuid

  senderProfile Profile @relation(fields: [senderProfileId], references: [id])

  type MessageType @default(TEXT)

  content String?

  attachmentUrl String?

  status MessageStatus @default(SENT)

  sentAt DateTime @default(now())

  isEdited Boolean @default(false)

  editedAt DateTime?

  deletedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([chatId, sentAt(sort: Desc)])
  @@index([senderProfileId])
}

/////////////////////////////////////////////////
// SAFETY ENUMS
/////////////////////////////////////////////////

enum ReportReason {
  FAKE_PROFILE
  INAPPROPRIATE_CONTENT
  HARASSMENT
  SPAM
  SCAM
  UNDERAGE
  IMPERSONATION
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum ModerationActionType {
  WARNING
  TEMP_SUSPENSION
  PERMANENT_BAN
  SHADOW_BAN
}

model Block {
  id String @id @default(uuid()) @db.Uuid

  blockerProfileId String @db.Uuid

  blocker Profile @relation("ProfileBlocks", fields: [blockerProfileId], references: [id], onDelete: Cascade)

  blockedProfileId String @db.Uuid

  blocked Profile @relation("BlockedByProfiles", fields: [blockedProfileId], references: [id], onDelete: Cascade)

  reason String?

  createdAt DateTime @default(now())

  @@unique([blockerProfileId, blockedProfileId])
  @@index([blockedProfileId])
}

model Report {
  id String @id @default(uuid()) @db.Uuid

  reporterProfileId String @db.Uuid

  reporter Profile @relation("ReportsCreated", fields: [reporterProfileId], references: [id])

  reportedProfileId String @db.Uuid

  reported Profile @relation("ReportsReceived", fields: [reportedProfileId], references: [id])

  reason ReportReason

  description String?

  status ReportStatus @default(PENDING)

  assignedAdminId String? @db.Uuid

  resolvedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  evidence ReportEvidence[]

  @@index([reportedProfileId])
  @@index([reporterProfileId])
  @@index([status])
}

model ReportEvidence {
  id String @id @default(uuid()) @db.Uuid

  reportId String @db.Uuid

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  storageKey String

  fileUrl String

  createdAt DateTime @default(now())

  @@index([reportId])
}

model ModerationAction {
  id String @id @default(uuid()) @db.Uuid

  userId String @db.Uuid

  user User @relation("UserModerationActions", fields: [userId], references: [id], onDelete: Restrict)

  adminId String @db.Uuid

  admin User @relation("AdminModerationActions", fields: [adminId], references: [id])

  actionType ModerationActionType

  reason String

  expiresAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([adminId])
  @@index([actionType])
}
